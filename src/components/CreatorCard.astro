---
import type { CollectionEntry } from 'astro:content';

interface Props {
  creator: CollectionEntry<'creators'>;
  count?: number;
}

const { creator, count } = Astro.props;
---

<a class="creator-card" href={`/creators/${creator.slug}/`}>
  <span class="creator-name">{creator.data.name}</span>
  <span class="creator-platform">{creator.data.platform}</span>
  {count !== undefined && <span class="creator-count">{count} summaries</span>}
</a>

<style>
  .creator-card {
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .creator-card:hover { border-color: #aaa; }
  .creator-name { font-weight: bold; font-size: 0.95rem; color: #1a1a1a; }
  .creator-platform {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #888;
  }
  .creator-count { font-size: 0.8rem; color: #888; }
</style>
