---
import type { CollectionEntry } from 'astro:content';

interface Props {
  spark: CollectionEntry<'sparks'>;
}

const { spark } = Astro.props;
const url = `/${spark.data.category}/${spark.slug}/`;
---

<article class="card">
  <a class="card-category" href={`/${spark.data.category}/`}>{spark.data.category}</a>
  <a class="card-title" href={url}>{spark.data.title}</a>
  <div class="card-meta">
    <a href={`/creators/${spark.data.creator}/`}>{spark.data.creator.replace(/-/g, ' ')}</a>
    · {spark.data.readTime} min read
    · {spark.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
  </div>
  <div class="card-tags">
    {spark.data.tags.slice(0, 2).map(tag => (
      <a href={`/tag/${tag}/`}>#{tag}</a>
    ))}
  </div>
</article>

<style>
  .card {
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: border-color 0.15s;
  }
  .card:hover { border-color: #aaa; }

  .card-category {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #888;
    text-decoration: none;
  }
  .card-title {
    font-size: 1rem;
    font-weight: bold;
    line-height: 1.4;
    text-decoration: none;
    color: #1a1a1a;
  }
  .card-title:hover { text-decoration: underline; }
  .card-meta { font-size: 0.8rem; color: #888; }
  .card-meta a { color: #888; text-decoration: none; }
  .card-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .card-tags a {
    font-size: 0.75rem;
    color: #666;
    background: #f5f5f5;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    text-decoration: none;
  }
</style>
