---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="This page doesn't exist on Realspark.">
  <div style="text-align:center; padding: 4rem 0;">
    <h1 style="font-size:3rem; margin-bottom:1rem;">404</h1>
    <p style="color:#666; margin-bottom:2rem;">This page doesn't exist — or it moved.</p>
    <a href="/" style="background:#1a1a1a; color:#fff; padding:0.6rem 1.4rem; border-radius:4px; text-decoration:none;">
      Back to home
    </a>
  </div>
</BaseLayout>
