---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const creators = await getCollection('creators');
  return creators.map(creator => ({ params: { slug: creator.slug }, props: { creator } }));
}

const { creator } = Astro.props;

const allSparks = await getCollection('sparks', ({ data }) => data.status === 'published');
const creatorSparks = allSparks
  .filter(s => s.data.creator === creator.slug)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const themes = [...new Set(creatorSparks.flatMap(s => s.data.tags))];
---

<BaseLayout title={`${creator.data.name} — Realspark`}>
  <nav class="breadcrumb">
    <a href="/">Home</a> › <a href="/creators/">Creators</a> › {creator.data.name}
  </nav>

  <header class="creator-header">
    <h1>{creator.data.name}</h1>
    <span class="platform-badge">{creator.data.platform}</span>
    <p>{creator.data.bio}</p>
    <a href={creator.data.externalUrl} target="_blank" rel="noopener">
      Visit their channel →
    </a>
  </header>

  <section>
    <h2>Recurring Themes</h2>
    <div class="tags">
      {themes.map(tag => <a href={`/tag/${tag}/`}>#{tag}</a>)}
    </div>
  </section>

  <section>
    <h2>All Summaries ({creatorSparks.length})</h2>
    <div class="grid">
      {creatorSparks.map(spark => <ArticleCard spark={spark} />)}
    </div>
  </section>
</BaseLayout>
