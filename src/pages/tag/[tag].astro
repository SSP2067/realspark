---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const sparks = await getCollection('sparks', ({ data }) => data.status === 'published');
  const tags = [...new Set(sparks.flatMap(s => s.data.tags))];
  return tags.map(tag => ({
    params: { tag },
    props: { sparks: sparks.filter(s => s.data.tags.includes(tag)) },
  }));
}

const { tag } = Astro.params;
const { sparks } = Astro.props;
const sorted = sparks.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title={`#${tag} — Realspark`}>
  <nav class="breadcrumb"><a href="/">Home</a> › #{tag}</nav>
  <h1>Articles tagged: {tag}</h1>
  <div class="grid">
    {sorted.map(spark => <ArticleCard spark={spark} />)}
  </div>
</BaseLayout>
