---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const sparks = await getCollection('sparks', ({ data }) =>
  data.status === 'published' && data.category === 'youtube'
);
const sorted = sparks.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="YouTube Summaries">
  <h1>YouTube Summaries</h1>
  <p style="color:#666; margin-bottom:2rem;">
    Short-form takeaways from the best YouTube creators — distilled for you.
  </p>
  <div class="grid">
    {sorted.map(spark => <ArticleCard spark={spark} />)}
  </div>
</BaseLayout>
