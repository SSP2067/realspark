---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Short, useful summaries of the best videos, books, and research.',
  image = '/og-default.png',
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Realspark</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} — Realspark`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Realspark" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — Realspark`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: 1.1rem;
        line-height: 1.75;
        color: #1a1a1a;
        background: #fff;
      }

      a { color: #1a1a1a; }
      a:hover { text-decoration: underline; }

      /* Nav */
      header {
        border-bottom: 1px solid #e5e5e5;
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        background: #fff;
        z-index: 10;
      }
      .site-name { font-size: 1.2rem; font-weight: bold; text-decoration: none; }
      nav { display: flex; gap: 1.5rem; font-size: 0.95rem; }
      nav a { text-decoration: none; }

      /* Content */
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }

      /* Article */
      h1 { font-size: 1.9rem; line-height: 1.3; margin-bottom: 0.75rem; }
      h2 { font-size: 1.2rem; margin: 2rem 0 0.5rem; }
      p  { margin-bottom: 1rem; }
      ul, ol { padding-left: 1.5rem; margin-bottom: 1rem; }
      li { margin-bottom: 0.4rem; }

      /* Breadcrumb */
      .breadcrumb { font-size: 0.85rem; color: #666; margin-bottom: 1.5rem; }
      .breadcrumb a { color: #666; }

      /* Meta row */
      .meta { font-size: 0.85rem; color: #666; margin-bottom: 2rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }
      .meta a { color: #666; }
      .badge {
        background: #f0f0f0;
        border-radius: 4px;
        padding: 0.1rem 0.5rem;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      /* Tags */
      .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 1.5rem 0; }
      .tags a {
        font-size: 0.85rem;
        color: #555;
        background: #f5f5f5;
        border-radius: 4px;
        padding: 0.2rem 0.6rem;
        text-decoration: none;
      }
      .tags a:hover { background: #e5e5e5; }

      /* Callout blocks */
      .callout {
        border-left: 3px solid #1a1a1a;
        padding: 0.75rem 1rem;
        margin: 1.5rem 0;
        background: #fafafa;
        font-size: 0.95rem;
      }
      .callout a { font-weight: bold; }

      /* Source block */
      .source-block {
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        padding: 1rem 1.25rem;
        margin: 2rem 0;
        font-size: 0.9rem;
        line-height: 1.6;
      }

      /* Grid */
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.5rem;
        margin: 1.5rem 0;
      }

      /* Sections */
      section { margin: 3rem 0; }
      section h2 { font-size: 1.3rem; margin-bottom: 1rem; }

      /* Hero */
      .hero { text-align: center; padding: 3rem 0 2rem; border-bottom: 1px solid #e5e5e5; margin-bottom: 3rem; }
      .hero h1 { font-size: 2rem; max-width: 600px; margin: 0 auto 1rem; }
      .hero p { color: #555; margin-bottom: 1.5rem; }
      .hero a {
        display: inline-block;
        background: #1a1a1a;
        color: #fff;
        padding: 0.6rem 1.4rem;
        border-radius: 4px;
        text-decoration: none;
        font-size: 0.95rem;
      }

      /* Creator header */
      .creator-header { margin-bottom: 2rem; }
      .platform-badge {
        display: inline-block;
        background: #f0f0f0;
        border-radius: 4px;
        padding: 0.15rem 0.5rem;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
      }

      /* Footer */
      footer {
        border-top: 1px solid #e5e5e5;
        padding: 2rem;
        font-size: 0.85rem;
        color: #666;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
      footer a { color: #666; }
      footer nav { display: flex; gap: 1rem; }

      /* Related */
      .related { margin-top: 3rem; border-top: 1px solid #e5e5e5; padding-top: 2rem; }

      @media (max-width: 600px) {
        header { padding: 1rem; }
        nav { gap: 1rem; font-size: 0.85rem; }
        .hero h1 { font-size: 1.5rem; }
        .grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <header>
      <a href="/" class="site-name">Realspark</a>
      <nav>
        <a href="/youtube/">YouTube</a>
        <a href="/creators/">Creators</a>
        <a href="/deep/">Deep Sparks</a>
        <a href="/about/">About</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <span>Realspark — Big ideas, fast reads</span>
      <nav>
        <a href="/">Home</a>
        <a href="/youtube/">YouTube</a>
        <a href="/creators/">Creators</a>
        <a href="/deep/">Deep Sparks</a>
        <a href="/about/">About</a>
      </nav>
      <span>© {new Date().getFullYear()} Realspark</span>
    </footer>
  </body>
</html>
