---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const deepSparks = await getCollection('deep', ({ data }) => data.status === 'published');
const sorted = deepSparks.sort((a, b) => b.data.lastUpdated.valueOf() - a.data.lastUpdated.valueOf());
---

<BaseLayout title="Deep Sparks">
  <h1>Deep Sparks</h1>
  <p style="color:#666; margin-bottom:2rem;">
    Long-form synthesis articles built from multiple related summaries. Updated as new posts are published.
  </p>
  {sorted.length === 0 && (
    <p style="color:#888;">First Deep Spark coming soon — check back after more summaries accumulate.</p>
  )}
  <div class="grid">
    {sorted.map(deep => (
      <article class="card" style="border:1px solid #e5e5e5; border-radius:6px; padding:1.25rem;">
        <a href={`/deep/${deep.slug}/`} style="font-weight:bold; font-size:1rem; text-decoration:none; color:#1a1a1a;">
          {deep.data.title}
        </a>
        <div style="font-size:0.8rem; color:#888; margin-top:0.4rem;">
          {deep.data.readTime} min read · Updated {deep.data.lastUpdated.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
          · {deep.data.contributingSparks.length} sources
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
